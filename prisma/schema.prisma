generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStage {
  ORDERED
  TRACKING_READY
  TRACKING_SUBMITTED
  DELIVERED
  SCANNED
  PAID_OUT
  CREDIT_PAID
  PROFIT_RECEIVED
}

enum PayoutMode {
  MANUAL
  PERCENT_SPREAD
}

enum WorkspaceType {
  PERSONAL
  OPERATOR
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceMemberStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

model Profile {
  id                     String            @id @default(cuid())
  authUserId             String            @unique
  name                   String?
  firstName              String?
  lastName               String?
  email                  String
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  ownedWorkspaces        Workspace[]       @relation("WorkspaceOwner")
  memberships            WorkspaceMember[]
  createdOrders          Order[]           @relation("OrderCreatedBy")
  submittedOrders        Order[]           @relation("OrderSubmittedBy")
  assignedOperatorOrders Order[]           @relation("OrderAssignedOperator")
  trackingChangeAlerts   TrackingChangeAlert[] @relation("TrackingChangeAlertMember")
  deliveryBeforeTrackingAlerts DeliveryBeforeTrackingAlert[] @relation("DeliveryBeforeTrackingAlertMember")

  @@index([email])
}

model Workspace {
  id             String            @id @default(cuid())
  name           String
  type           WorkspaceType
  ownerProfileId String
  inviteCode     String            @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  owner          Profile           @relation("WorkspaceOwner", fields: [ownerProfileId], references: [id], onDelete: Cascade)
  members        WorkspaceMember[]
  accounts       AmazonAccount[]
  creditCards    CreditCard[]
  buyGroups      BuyGroup[]
  warehouses     Warehouse[]
  orders         Order[]
  trackingChangeAlerts TrackingChangeAlert[]
  deliveryBeforeTrackingAlerts DeliveryBeforeTrackingAlert[]
  reminderStates ReminderState[]

  @@index([ownerProfileId])
  @@index([type])
}

model WorkspaceMember {
  id          String                @id @default(cuid())
  workspaceId String
  profileId   String
  role        WorkspaceRole
  status      WorkspaceMemberStatus @default(ACTIVE)
  emailNotificationsEnabled Boolean @default(true)
  slackNotificationsEnabled Boolean @default(true)
  reminderNotificationsEnabled Boolean @default(true)
  joinedAt    DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  profile     Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, profileId])
  @@index([profileId])
  @@index([workspaceId, role])
  @@index([workspaceId, status])
}

model AmazonAccount {
  id                       String     @id @default(cuid())
  userId                   String?
  workspaceId              String?
  name                     String
  defaultCreditCardDueDays Int?
  createdAt                DateTime   @default(now())
  workspace                Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders                   Order[]

  @@unique([userId, name])
  @@unique([workspaceId, name])
  @@index([userId])
  @@index([workspaceId])
}

model CreditCard {
  id                        String     @id @default(cuid())
  userId                    String?
  workspaceId               String?
  name                      String
  issuer                    String?
  last4                     String?
  creditLimit               Float      @default(0)
  utilizationWarningPercent Float      @default(30)
  cashbackOptions           Json?
  defaultCashbackPercent    Float      @default(5)
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  workspace                 Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders                    Order[]

  @@unique([workspaceId, userId, name])
  @@index([userId])
  @@index([workspaceId])
}

model BuyGroup {
  id          String     @id @default(cuid())
  userId      String?
  workspaceId String?
  name        String
  createdAt   DateTime   @default(now())
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([userId, name])
  @@unique([workspaceId, name])
  @@index([userId])
  @@index([workspaceId])
}

model Warehouse {
  id          String     @id @default(cuid())
  userId      String?
  workspaceId String?
  name        String
  code        String
  createdAt   DateTime   @default(now())
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([userId, name])
  @@unique([userId, code])
  @@unique([workspaceId, name])
  @@unique([workspaceId, code])
  @@index([userId])
  @@index([workspaceId])
}

model Order {
  id                                 String         @id @default(cuid())
  itemName                           String
  quantity                           Int
  retailPrice                        Float
  payoutPerUnit                      Float
  warehousePayoutPerUnit             Float?
  warehouseTotalPayout               Float?
  memberPayoutPerUnit                Float?
  memberTotalPayout                  Float?
  adminSpreadPerUnit                 Float?
  adminTotalSpread                   Float?
  adminSpreadPercent                 Float?
  payoutMode                         PayoutMode     @default(PERCENT_SPREAD)
  chaseCashbackPercent               Float          @default(0)
  youngAdultEligible                 Boolean        @default(false)
  youngAdultBalanceUsed              Boolean        @default(false)
  sameTracking                       Boolean        @default(false)
  shippingType                       String?
  orderNumber                        String?
  trackingNumber                     String?
  trackingSubmitted                  Boolean        @default(false)
  committedToWarehouse               Boolean        @default(false)
  delivered                          Boolean        @default(false)
  scanned                            Boolean        @default(false)
  paidOut                            Boolean        @default(false)
  creditCardPaid                     Boolean        @default(false)
  profitReceived                     Boolean        @default(false)
  memberSubmittedTrackingToAdmin     Boolean        @default(false)
  adminCommittedToWarehouse          Boolean        @default(false)
  adminSubmittedTrackingToWarehouse  Boolean        @default(false)
  memberMarkedDelivered              Boolean        @default(false)
  adminMarkedScannedByWarehouse      Boolean        @default(false)
  adminReceivedPayoutFromWarehouse   Boolean        @default(false)
  adminPaidMember                    Boolean        @default(false)
  currentStage                       OrderStage     @default(ORDERED)
  notes                              String?
  manualCreditCardDueDate            DateTime?
  payoutReminderSnoozedAt            DateTime?
  createdAt                          DateTime       @default(now())
  trackingAddedAt                    DateTime?
  committedToWarehouseAt             DateTime?
  trackingSubmittedAt                DateTime?
  deliveredAt                        DateTime?
  scannedAt                          DateTime?
  paidOutAt                          DateTime?
  creditCardPaidAt                   DateTime?
  profitReceivedAt                   DateTime?
  memberSubmittedTrackingToAdminAt   DateTime?
  adminCommittedToWarehouseAt        DateTime?
  adminSubmittedTrackingToWarehouseAt DateTime?
  memberMarkedDeliveredAt            DateTime?
  adminMarkedScannedByWarehouseAt    DateTime?
  adminReceivedPayoutFromWarehouseAt DateTime?
  adminPaidMemberAt                  DateTime?
  updatedAt                          DateTime       @updatedAt
  userId                             String?
  workspaceId                        String?
  submittedByProfileId               String?
  createdByProfileId                 String?
  assignedOperatorProfileId          String?
  memberPaid                         Boolean        @default(false)
  memberPaidAt                       DateTime?
  memberConfirmedPayment             Boolean        @default(false)
  memberConfirmedPaymentAt           DateTime?
  memberMarkedDone                   Boolean        @default(false)
  memberMarkedDoneAt                 DateTime?
  memberPayoutAmount                 Float?
  memberVisibleNotes                 String?
  internalAdminNotes                 String?
  adminSubmittedTrackingToBuyGroup   Boolean        @default(false)
  adminSubmittedTrackingToBuyGroupAt DateTime?
  warehouseScanned                   Boolean        @default(false)
  warehouseScannedAt                 DateTime?
  buyGroupPaidAdmin                  Boolean        @default(false)
  buyGroupPaidAdminAt                DateTime?
  adminProfit                        Float?
  adminMargin                        Float?
  amazonAccountId                    String?
  creditCardId                       String?
  buyGroupId                         String?
  warehouseId                        String?
  workspace                          Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submittedBy                        Profile?       @relation("OrderSubmittedBy", fields: [submittedByProfileId], references: [id], onDelete: SetNull)
  createdBy                          Profile?       @relation("OrderCreatedBy", fields: [createdByProfileId], references: [id], onDelete: SetNull)
  assignedOperator                   Profile?       @relation("OrderAssignedOperator", fields: [assignedOperatorProfileId], references: [id], onDelete: SetNull)
  amazonAccount                      AmazonAccount? @relation(fields: [amazonAccountId], references: [id], onDelete: SetNull)
  creditCard                         CreditCard?    @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  buyGroup                           BuyGroup?      @relation(fields: [buyGroupId], references: [id], onDelete: SetNull)
  warehouse                          Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  trackingChangeAlerts               TrackingChangeAlert[]
  deliveryBeforeTrackingAlerts       DeliveryBeforeTrackingAlert[]
  reminderStates                     ReminderState[]

  @@index([userId])
  @@index([workspaceId])
  @@index([submittedByProfileId])
  @@index([createdByProfileId])
  @@index([assignedOperatorProfileId])
  @@index([workspaceId, submittedByProfileId])
  @@index([workspaceId, memberPaid])
  @@index([workspaceId, memberConfirmedPayment])
  @@index([workspaceId, memberMarkedDone])
  @@index([currentStage])
  @@index([amazonAccountId])
  @@index([creditCardId])
  @@index([buyGroupId])
  @@index([warehouseId])
}

model ReminderState {
  id          String    @id @default(cuid())
  workspaceId String
  orderId     String
  type        String
  reviewedAt  DateTime?
  snoozedUntil DateTime?
  lastSentAt   DateTime?
  resolvedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, type])
  @@index([workspaceId, reviewedAt, snoozedUntil])
  @@index([workspaceId, orderId])
}

model DeliveryBeforeTrackingAlert {
  id             String    @id @default(cuid())
  workspaceId    String
  orderId        String
  memberProfileId String?
  deliveredAt    DateTime
  reviewedAt     DateTime?
  snoozedUntil   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  member         Profile?  @relation("DeliveryBeforeTrackingAlertMember", fields: [memberProfileId], references: [id], onDelete: SetNull)

  @@index([workspaceId, reviewedAt, snoozedUntil])
  @@index([workspaceId, createdAt])
  @@index([orderId])
  @@index([memberProfileId])
}

model TrackingChangeAlert {
  id                         String    @id @default(cuid())
  workspaceId                String
  orderId                    String
  memberProfileId            String?
  oldTrackingNumber          String?
  newTrackingNumber          String?
  changedAt                  DateTime  @default(now())
  reviewedAt                 DateTime?
  snoozedUntil               DateTime?
  warehouseTrackingUpdatedAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  workspace                  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  order                      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  member                     Profile?  @relation("TrackingChangeAlertMember", fields: [memberProfileId], references: [id], onDelete: SetNull)

  @@index([workspaceId, reviewedAt, snoozedUntil])
  @@index([workspaceId, changedAt])
  @@index([orderId])
  @@index([memberProfileId])
}
